# LLM
GROQ_API_KEY=gsk_your_actual_key_here
CREW_LLM_MODEL=groq/llama-3.3-70b-versatile
# or ANTHROPIC_API_KEY=sk-ant-... (if you point crewai's LLM at Claude via litellm)

# Auth
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./fitness.db

# External tool APIs
EXERCISEDB_API_KEY=your-rapidapi-exercisedb-key
SPOONACULAR_API_KEY=your-spoonacular-key
RESEND_API_KEY=your-resend-api-key
NOTIFICATION_FROM_EMAIL=onboarding@resend.dev

# Vector store (for RAG safety-check agent)
CHROMA_PERSIST_DIR=./chroma_store
